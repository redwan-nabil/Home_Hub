#!/bin/bash

if [ -z "$1" ]; then
    echo "Usage: publish <file_to_publish>"
    exit 1
fi

FILE="$1"
FILENAME=$(basename "$FILE")
STAGING_DIR="/home/redwannabil/portfolio_staging"

echo " "
read -p "📁 Enter the Project Folder name: " PROJECT_FOLDER
PROJECT_FOLDER=$(echo "$PROJECT_FOLDER" | tr ' ' '_')

if [ ! -f "$FILE" ]; then
    echo "❌ Error: File '$FILE' does not exist."
    exit 1
fi

# --- THE PERMANENT FIX: SYNC FIRST, THEN STAGE ---
echo "🔄 Syncing with Cloud AI..."
cd "$STAGING_DIR"
git pull origin main --rebase
# Wipe any ghost folders left behind locally
rm -rf "$STAGING_DIR/incoming/*"

# Now create the fresh staging folder
TARGET_DIR="$STAGING_DIR/incoming/$PROJECT_FOLDER"
mkdir -p "$TARGET_DIR"

cp "$FILE" "$TARGET_DIR/$FILENAME"
TARGET="$TARGET_DIR/$FILENAME"

echo "🛡️ Sanitizing '$FILENAME' for public GitHub..."
sed -i -E 's/([Tt][Oo][Kk][Ee][Nn]\s*=\s*).*/\1"REDACTED_BY_SYSADMIN"/' "$TARGET"
sed -i -E 's/([Pp][Aa][Ss][Ss][Ww][Oo][Rr][Dd]\s*=\s*).*/\1"REDACTED_BY_SYSADMIN"/' "$TARGET"
sed -i -E 's/([Cc][Hh][Aa][Tt]_[Ii][Dd]\s*=\s*).*/\1"REDACTED_BY_SYSADMIN"/' "$TARGET"
sed -i -E 's/([Aa][Pp][Ii]_[Kk][Ee][Yy]\s*=\s*).*/\1"REDACTED_BY_SYSADMIN"/' "$TARGET"
sed -i -E 's/([Ss][Mm][Bb]_[Pp][Aa][Ss][Ss]\s*=\s*).*/\1"REDACTED_BY_SYSADMIN"/' "$TARGET"

echo "✅ Scrubbing complete. '$FILENAME' safely staged."
echo "🚀 Handing off to GitHub Pusher..."
/home/redwannabil/github_pusher.sh
